{erl_opts, [debug_info]}.

{minimum_otp_vsn, "29"}.

{deps, [
    {roadrunner, "0.1.0"},
    {epgsql, "4.8.0"},
    {pooler, "1.6.0"}
]}.

{relx, [
    {release, {roadrunner_httparena, "0.1.0"},
        [roadrunner_httparena, roadrunner]},
    {sys_config, "./config/sys.config"},
    {dev_mode, false},
    {include_erts, true},
    {extended_start_script, true}
]}.

{profiles, [
    {prod, [
        {relx, [{mode, prod}]}
    ]}
]}.
